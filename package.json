{
  "name": "taskr",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first quick task management app",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "start": "cross-env NODE_ENV=production npm run start -w backend",
    "db:init": "npm run db:init -w backend",
    "db:seed": "npm run db:seed -w backend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm run test -w backend",
    "test:frontend": "npm run test -w frontend"
  },
  "devDependencies": {
    "concurrently": "8.2.2",
    "cross-env": "7.0.3"
  },
  "engines": {
    "node": ">=20.6.0",
    "npm": ">=9.0.0"
  }
}
